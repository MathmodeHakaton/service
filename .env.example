# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ru_liquidity_sentinel

# APIs
CBR_API_BASE_URL=https://www.cbr.ru/dev/api/
MINFIN_API_BASE_URL=https://minfin.gov.ru/api/
ROSKAZNA_API_BASE_URL=https://www.roskazna.gov.ru/api/
FNS_API_BASE_URL=https://service.nalog.ru/api/

# Cache
CACHE_DIR=./cache
CACHE_TTL_HOURS=24

# LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Logging
LOG_LEVEL=INFO

# Application
MAD_WINDOW_YEARS=3
LSI_THRESHOLD=0.7
